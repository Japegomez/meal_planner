# Copy to .env for local reference — values are passed at build/run time via --dart-define.
# Do NOT commit .env with real secrets.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Solo para generar modelos Dart (supadart). Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
